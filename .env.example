NODE_ENV=development
PORT=3000
# Supabase: Project Settings → Database → Connection string → URI (use Direct, port 5432 for TypeORM)
# Example: postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Prefer Session mode or Direct connection (5432) — avoid Transaction pooler quirks with ORMs unless configured.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.mmewgxnshmcciiacloks.supabase.co:5432/postgres
# Optional: force TLS (auto-enabled when host contains supabase.co)
DATABASE_SSL=true
# Local: default is redis://localhost:6379 if unset (development only).
# Render: omit Redis vars or set REDIS_DISABLED=true — Redis is optional; Postgres idempotency still works.
#
# Option A — single URI (Upstash, etc.):
# REDIS_URL=rediss://default:password@host:6379
#
# Option B — Redis Cloud / Redis Labs (same as node-redis host+port+username+password):
# REDIS_HOST=redis-xxxxx.c81.us-east-1-2.ec2.cloud.redislabs.com
# REDIS_PORT=13493
# REDIS_USERNAME=default
# REDIS_PASSWORD=your_password
# REDIS_TLS=false
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DISABLED=
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxx
CHAPA_WEBHOOK_SECRET=your_dashboard_webhook_secret_hash
API_KEY=
